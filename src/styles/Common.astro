---
import "@fontsource-variable/fredoka";
---

<style is:global>
  html,
  body {
    margin: auto;
    width: calc(100% - 1rem);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: #ff93ca;
  }

  main {
    flex: 1 1 0;
    display: flex;
    flex-direction: column;
    max-width: 700px;
    width: 100%;
    margin: auto;
  }

  p,
  h1,
  h2,
  h3,
  h4,
  h6,
  h6 {
    font-family: "Fredoka Variable";
    color: #272a49;
  }

  a {
    font-family: "Fredoka Variable";
    color: #844063;
  }
</style>
